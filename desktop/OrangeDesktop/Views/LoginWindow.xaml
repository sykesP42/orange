<Window x:Class="OrangeDesktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orange - 登录" Height="520" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#FFF5F0">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
            <TextBlock Text="🍊" FontSize="48" HorizontalAlignment="Center" Margin="0,10,0,5"/>
            <TextBlock Text="Orange Desktop" FontSize="24" FontWeight="Bold" Foreground="#FF6B35" HorizontalAlignment="Center"/>
            <TextBlock Text="博主管理系统" FontSize="13" Foreground="#999" HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ServerUrlBox"
                     Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}"
                     Height="32" VerticalContentAlignment="Center"
                     Padding="8,0"
                     BorderBrush="#DDD" BorderThickness="1"
                     Grid.Column="0"/>
            <Button Content="测试连接" Command="{Binding TestConnectionCommand}"
                    Height="32" Padding="12,0" Margin="5,0,0,0"
                    Background="#E8E8E8" Foreground="#333"
                    BorderThickness="0" Cursor="Hand"
                    Grid.Column="1"/>
        </Grid>

        <TextBox Grid.Row="3"
                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                 Height="38" VerticalContentAlignment="Center"
                 Padding="10,0" Margin="0,8,0,0"
                 BorderBrush="#DDD" BorderThickness="1">
            <TextBox.ToolTip>用户名</TextBox.ToolTip>
        </TextBox>

        <PasswordBox x:Name="PasswordBox"
                     Grid.Row="4"
                     Height="38" VerticalContentAlignment="Center"
                     Padding="10,0" Margin="0,8,0,0"
                     BorderBrush="#DDD" BorderThickness="1"
                     PasswordChanged="PasswordBox_PasswordChanged"/>

        <TextBox Grid.Row="5"
                 Text="{Binding RealName, UpdateSourceTrigger=PropertyChanged}"
                 Height="38" VerticalContentAlignment="Center"
                 Padding="10,0" Margin="0,8,0,0"
                 BorderBrush="#DDD" BorderThickness="1"
                 Visibility="{Binding IsRegisterMode, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBox.ToolTip>真实姓名</TextBox.ToolTip>
        </TextBox>

        <TextBlock Grid.Row="6"
                   Text="{Binding ErrorMessage}"
                   Foreground="#E74C3C" FontSize="12"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NotNullToVisibilityConverter}}"/>

        <Button Grid.Row="7"
                Content="{Binding IsRegisterMode, Converter={StaticResource LoginRegisterTextConverter}}"
                Command="{Binding LoginCommand}"
                Height="40" Margin="0,12,0,0"
                Background="#FF6B35" Foreground="White"
                BorderThickness="0" Cursor="Hand"
                FontSize="14" FontWeight="Medium">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E55A2B"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>

        <TextBlock Grid.Row="8" Margin="0,12,0,0" HorizontalAlignment="Center">
            <Hyperlink Command="{Binding ToggleModeCommand}"
                       Foreground="#FF6B35" TextDecorations="None">
                <Run Text="{Binding IsRegisterMode, Converter={StaticResource ToggleTextConverter}}"/>
            </Hyperlink>
        </TextBlock>

        <StackPanel Grid.Row="9" VerticalAlignment="Bottom" HorizontalAlignment="Center">
            <TextBlock Text="连接服务器后即可使用" FontSize="11" Foreground="#BBB" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
